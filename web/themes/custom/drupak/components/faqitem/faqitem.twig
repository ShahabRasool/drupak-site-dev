  <!-- FAQ ITEM 1 -->
                    <div class=" faq transition-all duration-400 ease-in" x-data="{ open: false }">
                        <div class="question cursor-pointer   py-3 px-5 flex justify-between items-center bg-gradient-to-r from-primary/30 via-primary/20 to-primary/40 border border-primary rounded text-text/70 "
                            @click="open = !open">
                            <h5 class="text-para font-bold">{{ title }}</h5>
                            <span class="fill-primary" :class="{'hidden': open}">
                                <svg width="18" height="18" viewBox="0 0 20 20"  xmlns="http://www.w3.org/2000/svg">
                                    <path d="M11.4286 8.57143V1.42857C11.4286 1.04969 11.2781 0.686328 11.0102 0.418419C10.7422 0.15051 10.3789 0 10 0C9.62112 0 9.25776 0.15051 8.98985 0.418419C8.72194 0.686328 8.57143 1.04969 8.57143 1.42857V8.57143H1.42857C1.04969 8.57143 0.686328 8.72194 0.418419 8.98985C0.15051 9.25776 0 9.62112 0 10C0 10.3789 0.15051 10.7422 0.418419 11.0102C0.686328 11.2781 1.04969 11.4286 1.42857 11.4286H8.57143V18.5714C8.57143 18.9503 8.72194 19.3137 8.98985 19.5816C9.25776 19.8495 9.62112 20 10 20C10.3789 20 10.7422 19.8495 11.0102 19.5816C11.2781 19.3137 11.4286 18.9503 11.4286 18.5714V11.4286H18.5714C18.9503 11.4286 19.3137 11.2781 19.5816 11.0102C19.8495 10.7422 20 10.3789 20 10C20 9.62112 19.8495 9.25776 19.5816 8.98985C19.3137 8.72194 18.9503 8.57143 18.5714 8.57143H11.4286Z" />
                                </svg>
                            </span>
                            <span class="fill-primary" :class="{'hidden': !open}">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 304 384"><path   d="M299 213H0v-42h299v42z"/></svg>
                            </span>
                        </div>
                        <div class="answer px-3  sm:px-5 pt-2.5 overflow-hidden transition-all duration-400 ease-in"
                            x-ref="answer"
                            x-bind:style="open ? 'max-height: ' + $refs.answer.scrollHeight + 'px' : 'max-height: 0px'">
                            <p class="text-para text-text/70">{{ description}}
                            </p>
                        </div>
                    </div>