

        <section class="container-px text-tertiary py-[clamp(60px,10dvh,100px)] bg-body-bg">
	<div
		class="relative mx-auto max-w-480 bg-grey-bg rounded-[clamp(10px,1dvw,20px)] overflow-hidden">
		<!-- Text -->
		<div class="relative z-10 w-full grid grid-cols-1 gap-[clamp(20px,3dvw,40px)] p-[clamp(20px,3dvw,80px)] text-left md:w-1/2">
			<h2 class="uppercase text-h2 relative z-10 pb-5 font-montserrat text-tertiary basis-1/3 after:h-1 after:w-15 after:content-[] after:bg-tertiary after:absolute after:bottom-0 after:left-0">
				{{ title }}
			</h2>

			<p class="relative z-10 text-p max-w-145">
				{{ description }}
			</p>

			{% if cta %}
				<div class="flex self-start  flex-col md:flex-row gap-3.75">
					{{ cta }}
				</div>
			{% endif %}
		</div>

		<!-- Image -->
		<div class="absolute top-0 right-0 z-0 overflow-hidden">
			{% if image %}
				<img src="{{ image }}" class="block w-full h-full object-contain opacity-50 md:!opacity-90"/>
			{% endif %}
		</div>
	</div>
</section>
