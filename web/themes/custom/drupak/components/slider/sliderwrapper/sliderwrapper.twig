{{ attach_library('drupak/swiper-custom') }}

<div class="w-full container-px py-10 md:py-16 bg-gradient-to-br from-slate-50 to-gray-900">
  <div class="slider-wrapper">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 md:mb-14 gap-5">
      <div class="space-y-2">
        <span class="text-sm font-semibold uppercase tracking-wider text-blue-600 bg-blue-50 px-3 py-1 rounded-full inline-block">
          {{ title }}
        </span>

        <div class="text-slate-500 max-w-xl text-base md:text-lg">
          {{ description }}
        </div>
      </div>

      {% if cta %}
        <div class="flex gap-3.75">
          {{ cta }}
        </div>
      {% endif %}
    </div>

    <!-- Slider wrapper (IMPORTANT for arrows spacing) -->
    <div class="relative">

      <div class="swiper mySwiper">
        <div class="swiper-wrapper">

          {{ content }}
          

        </div>

        <!-- Controls -->
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>

      <!-- Pagination OUTSIDE swiper -->
      <div class="swiper-pagination mt-6 text-center"></div>

    </div>

  </div>
</div>